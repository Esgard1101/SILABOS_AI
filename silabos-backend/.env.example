GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Modelos Google por familia de agentes.
# Producto acreditable: usa el consolidado global de NotebookLM cuando el docente lo pega.
GEMINI_PRODUCT_MODEL=
# Unidad: genera/repara la unidad usando el payload NotebookLM de esa unidad dentro del mismo prompt.
GEMINI_UNIT_MODEL=
# Tareas cortas: metodologia, tutoria, busqueda, bibliografia, metodos y pasos progresivos previos.
GEMINI_LIGHT_MODEL=
# Validacion/auditoria semantica.
GEMINI_AUDIT_MODEL=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSIONS=768
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FINAL_MODEL=gpt-5.4-mini
# OpenAI queda reservado como fallback caro solo para generacion/reparacion de unidades.
OPENAI_UNIT_MODEL=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Modelos NVIDIA nativos. Puedes escribirlos con o sin prefijo nvidia:.
NVIDIA_PRODUCT_MODELS=
NVIDIA_UNIT_MODELS=
NVIDIA_AUDIT_MODELS=
NVIDIA_LIGHT_MODELS=
# Legacy: el backend ya no decide por un switch global; enruta por tarea.
AI_PROVIDER=router
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cascadas por familia. Cada *_MODELS acepta lista separada por comas; tambien acepta nvidia:modelo.
OPENROUTER_PRODUCT_MODEL=
OPENROUTER_PRODUCT_MODELS=
OPENROUTER_UNIT_MODEL=
OPENROUTER_UNIT_MODELS=
OPENROUTER_AUDIT_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_AUDIT_MODELS=
OPENROUTER_LIGHT_MODEL=inclusionai/ling-2.6-1t:free
OPENROUTER_LIGHT_MODELS=
OPENROUTER_FALLBACK_MODEL=
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_AUDIT_REASONING=false
# Mistral: ULTIMO eslabon de resiliencia. Free Tier tiene limite global de
# 1 request/seg por API key, jamas usar como primario en llamadas paralelas.
MISTRAL_API_KEY=
# Pool 1 (50k tpm / 4M mensual): fallback critico de unidades.
MISTRAL_UNIT_MODEL=mistral-large-latest
# Pool 3 (375k tpm / sin limite mensual): fallback de resumenes/producto.
MISTRAL_PRODUCT_MODEL=mistral-medium-latest
# Pool 5 (20k tpm / 1B mensual): fallback de auditoria.
MISTRAL_AUDIT_MODEL=mistral-small-latest
# Fallback ligero (comparte pool small).
MISTRAL_LIGHT_MODEL=mistral-small-latest
AI_USAGE_LOG_PATH=logs/ai_usage.jsonl
# Alias legacy: se usa solo si OPENROUTER_AUDIT_MODEL no esta definido.
OPENROUTER_MODEL=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
FRONTEND_URL=https://tudominio.com
